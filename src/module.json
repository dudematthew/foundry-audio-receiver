{
    "id": "foundry-audio-receiver",
    "title": "Foundry Audio Receiver",
    "description": "Receives external audio streams and exposes a simple in-Foundry player.",
    "version": "0.1.0",
    "compatibility": { "minimum": "13", "verified": "13" },
    "authors": [
        {
            "name": "dudematthew"
        }
    ],
    "esmodules": ["main.js"],
    "styles": ["styles/audio-receiver.css"],
    "languages": [
        {
            "lang": "en",
            "name": "English",
            "path": "lang/en.json"
        },
        {
            "lang": "pl",
            "name": "Polski",
            "path": "lang/pl.json"
        }
    ],
    "socket": true,
    "flags": {
        "hotReload": {
            "extensions": ["css", "json"],
            "paths": ["styles", "lang"]
        }
    }
}